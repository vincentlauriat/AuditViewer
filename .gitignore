# État OMC (orchestration locale)
.omc/

# Réglages Claude Code locaux à la machine
.claude/settings.local.json

# Dossiers de sortie d'audit générés par le skill (créés à la racine d'exécution)
# Ancré à la racine pour ne PAS exclure skills/audit-report/ (le skill lui-même)
/audit-*/

# Fixtures de développement locales (données d'audit, ne pas publier)
/viewer-fixtures/

# Artefacts macOS / éditeurs
.DS_Store
*.swp
.idea/
.vscode/

# Doublons de conflit iCloud (le dépôt vit sous ~/Documents synchronisé iCloud)
# ex. « LANServer 2.swift » — cassent le build s'ils traînent dans Sources/
* 2.swift
* 3.swift
